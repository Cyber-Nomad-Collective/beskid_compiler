type User { event{4} Created(string payload) }

impl User {
    unit Emit(string payload) {
        this.Created(payload);
    }
}

i32 main() {
    User mut u = User { };
    unit(string) boom = (string payload) => { __panic_str("boom"); };
    u.Created += boom;
    u.Created -= boom;
    return 0;
}
