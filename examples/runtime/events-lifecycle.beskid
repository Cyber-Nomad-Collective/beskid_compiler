type User { event{4} Created(string payload) }

impl User {
    unit Emit(string payload) {
        this.Created(payload);
    }
}

i64 main() {
    User mut u = User { };
    unit(string) handler = (string payload) => { __sys_println(payload); };
    u.Created += handler;
    u.Emit("created");
    u.Created -= handler;
    return 0;
}
